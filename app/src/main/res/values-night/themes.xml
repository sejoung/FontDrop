<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Mirror the light theme until dark mode is formally designed. Keeps system
         window decor consistent with the Compose scheme we force in FontDropTheme. -->
    <style name="Theme.Fontdrop" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/paper_50</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/paper_50</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:windowBackground">@color/paper_50</item>
    </style>
</resources>
